/*
 * ----------------------------------------------------------------------------
 *  conf/test_full.config
 *
 *  Placeholder for a full-size cloud test. nf-core community pipelines
 *  use this profile to run on AWS megatests with a real-size dataset.
 *  This personal-repo pipeline does not have AWS megatest infrastructure
 *  yet — see "What I would add next" in the README.
 *
 *  When this is wired up, point `input` at a public PacBio HiFi sample
 *  (e.g. HG002 chr22 subset) on s3:// and uncomment the cloud profile
 *  hooks below.
 * ----------------------------------------------------------------------------
 */

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full-size test (placeholder — see test_full.config)'

    // TODO(v0.2.0): wire to a real public HiFi sample.
    input     = "${projectDir}/tests/samplesheet_test.csv"
    reference = "${projectDir}/tests/test_data/ref.fa"
    outdir    = './results-test-full'
}
