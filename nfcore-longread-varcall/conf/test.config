/*
 * ----------------------------------------------------------------------------
 *  conf/test.config
 *
 *  Tiny end-to-end smoke test. Designed to run the *entire* pipeline on
 *  synthetic data in under 5 minutes on a laptop. The test data lives in
 *  tests/test_data/ and is generated by bin/make_test_data.py — see
 *  tests/README.md for the planted variants.
 *
 *  Activate with:  nextflow run . -profile test,docker
 * ----------------------------------------------------------------------------
 */

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal synthetic dataset to smoke-test the full pipeline.'

    // Tiny resource ceilings so the test profile is friendly on a laptop.
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '1.h'

    // Tiny synthetic samplesheet — paths are relative to projectDir so the
    // test profile is portable.
    input     = "${projectDir}/tests/samplesheet_test.csv"
    reference = "${projectDir}/tests/test_data/ref.fa"
    outdir    = './results-test'

    // Loosen filtering on the synthetic VCF — synthetic QUAL/DP are low.
    min_qual = 1
    min_dp   = 1
}
