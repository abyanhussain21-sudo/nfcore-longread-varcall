/*
 * ----------------------------------------------------------------------------
 *  conf/modules.config
 *
 *  Per-module publishDir rules and `ext.args` strings. Centralising these
 *  here (rather than inside each module's `script:` block) means a user can
 *  override a tool's flags without forking the module — nf-core convention.
 *
 *  Reference: https://nf-co.re/docs/contributing/modules#configuring-modules
 * ----------------------------------------------------------------------------
 */

process {
    // ---- Default publishDir for every process unless overridden below ----
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // -------- Read QC --------
    withName: 'NANOPLOT' {
        publishDir = [
            path: { "${params.outdir}/qc/nanoplot/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'FASTQC' {
        ext.args = '--quiet'
        publishDir = [
            path: { "${params.outdir}/qc/fastqc/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // -------- Alignment --------
    withName: 'MINIMAP2_ALIGN' {
        // map-hifi preset is mandatory for PacBio HiFi reads.
        ext.args = '-ax map-hifi --MD -Y'
        publishDir = [
            path: { "${params.outdir}/alignment/minimap2/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,sam}'
        ]
    }
    withName: 'SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}.sorted" }
        publishDir = [
            path: { "${params.outdir}/alignment/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.bam'
        ]
    }
    withName: 'SAMTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/alignment/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.bai'
        ]
    }
    withName: 'SAMTOOLS_FLAGSTAT' {
        publishDir = [
            path: { "${params.outdir}/qc/samtools/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'MOSDEPTH' {
        ext.args = '--no-per-base --by 1000'
        publishDir = [
            path: { "${params.outdir}/qc/mosdepth/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // -------- Variant calling --------
    withName: 'DEEPVARIANT' {
        publishDir = [
            path: { "${params.outdir}/variants/snv/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{vcf.gz,vcf.gz.tbi,html}'
        ]
    }
    withName: 'SNIFFLES' {
        publishDir = [
            path: { "${params.outdir}/variants/sv/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{vcf.gz,vcf.gz.tbi}'
        ]
    }
    withName: 'BCFTOOLS_NORM' {
        ext.args = '--multiallelics -any --output-type z'
        ext.prefix = { "${meta.id}.${meta.vartype}.norm" }
        publishDir = [
            path: { "${params.outdir}/variants/${meta.vartype}/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{vcf.gz,vcf.gz.tbi}'
        ]
    }
    withName: 'BCFTOOLS_FILTER' {
        ext.args = { "--include 'QUAL>=${params.min_qual} && INFO/DP>=${params.min_dp}' --output-type z" }
        ext.prefix = { "${meta.id}.${meta.vartype}.filtered" }
        publishDir = [
            path: { "${params.outdir}/variants/${meta.vartype}/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{vcf.gz,vcf.gz.tbi}'
        ]
    }
    withName: 'BCFTOOLS_STATS' {
        publishDir = [
            path: { "${params.outdir}/variants/${meta.vartype}/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.stats.txt'
        ]
    }

    // -------- Reporting --------
    withName: 'MULTIQC' {
        ext.args = { params.multiqc_title ? "--title \"${params.multiqc_title}\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode
        ]
    }
}
