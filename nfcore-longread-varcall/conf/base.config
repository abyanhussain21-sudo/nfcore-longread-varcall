/*
 * ----------------------------------------------------------------------------
 *  conf/base.config
 *
 *  Default per-process resource allocations, scoped by process label
 *  (process_low / process_medium / process_high / process_long).
 *
 *  Modules pick a label via `label 'process_medium'` etc. — never hard-code
 *  cpus/memory inside a module. This is the nf-core idiom and lets users
 *  override resources from a single place.
 *
 *  All requests are clamped against params.max_cpus / max_memory / max_time
 *  by the check_max() helper defined in nextflow.config.
 * ----------------------------------------------------------------------------
 */

process {
    // Global retry policy — if a process exits with a memory-related code,
    // retry once with bumped resources before giving up. nf-core convention.
    cpus          = { check_max( 1    * task.attempt, 'cpus'   ) }
    memory        = { check_max( 4.GB * task.attempt, 'memory' ) }
    time          = { check_max( 4.h  * task.attempt, 'time'   ) }

    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // ---- Resource labels ----
    withLabel: process_low {
        cpus   = { check_max( 2     * task.attempt, 'cpus'   ) }
        memory = { check_max( 4.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 2.h   * task.attempt, 'time'   ) }
    }
    withLabel: process_medium {
        cpus   = { check_max( 6     * task.attempt, 'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h   * task.attempt, 'time'   ) }
    }
    withLabel: process_high {
        cpus   = { check_max( 12    * task.attempt, 'cpus'   ) }
        memory = { check_max( 48.GB * task.attempt, 'memory' ) }
        time   = { check_max( 16.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_long {
        time   = { check_max( 20.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_single {
        cpus   = { check_max( 1                   , 'cpus'   ) }
        memory = { check_max( 2.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 1.h   * task.attempt, 'time'   ) }
    }

    // Long-running variant callers benefit from the extra-time label too.
    withName: 'DEEPVARIANT' {
        label = 'process_high'
    }
    withName: 'MINIMAP2_ALIGN' {
        label = 'process_high'
    }
}
