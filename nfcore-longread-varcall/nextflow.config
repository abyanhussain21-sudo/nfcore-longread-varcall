/*
 * ----------------------------------------------------------------------------
 *  nfcore-longread-varcall
 *  Top-level Nextflow configuration
 *
 *  This file declares default pipeline parameters, profile definitions,
 *  manifest metadata, and resource caps. Profile-specific overrides live in
 *  conf/*.config; per-process resource defaults live in conf/base.config;
 *  per-module publishDir / ext.args live in conf/modules.config.
 *
 *  Convention follows nf-core (one config concern per file) so the layout
 *  is recognisable to anyone who has read an nf-core pipeline.
 * ----------------------------------------------------------------------------
 */

// ---------------------------------------------------------------------------
//  Default parameters — every parameter is also documented in
//  nextflow_schema.json which is the authoritative source for nf-schema
//  validation. Keep the two in sync.
// ---------------------------------------------------------------------------
params {
    // Input/output
    input                      = null    // path to samplesheet CSV
    outdir                     = './results'
    publish_dir_mode           = 'copy'

    // Reference (can also be set per-sample via the samplesheet)
    reference                  = null

    // Stage toggles
    skip_snv                   = false   // skip DeepVariant
    skip_sv                    = false   // skip Sniffles2
    skip_qc                    = false   // skip FastQC + NanoPlot
    skip_multiqc               = false

    // Filtering thresholds (bcftools filter)
    min_qual                   = 20
    min_dp                     = 10

    // DeepVariant
    deepvariant_model_type     = 'PACBIO'

    // Resource caps — overridable on the CLI; checked by check_max() helper
    max_cpus                   = 16
    max_memory                 = '64.GB'
    max_time                   = '24.h'

    // MultiQC
    multiqc_config             = "${projectDir}/assets/multiqc_config.yml"
    multiqc_title              = null

    // Boilerplate
    help                       = false
    version                    = false
    validate_params            = true
    show_hidden_params         = false
    monochrome_logs            = false
}

// ---------------------------------------------------------------------------
//  Load per-process resource defaults and module-specific publishDir rules.
// ---------------------------------------------------------------------------
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ---------------------------------------------------------------------------
//  Profiles — match nf-core conventions. Users compose: -profile test,docker
// ---------------------------------------------------------------------------
profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
    }
    docker {
        docker.enabled          = true
        docker.userEmulation    = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
    }
    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        // We do not ship per-module conda envs in v0.1.0 — the canonical
        // execution path is containers. Conda is here as a fallback for
        // environments where Docker/Singularity are unavailable. Users
        // should expect conda to be slower and may hit DeepVariant
        // packaging issues on macOS arm64 (see docs/usage.md).
    }
    test       { includeConfig 'conf/test.config'      }
    test_full  { includeConfig 'conf/test_full.config' }
}

// ---------------------------------------------------------------------------
//  Manifest — populates `nextflow run --version` and the launch banner.
// ---------------------------------------------------------------------------
manifest {
    name            = 'abyanhussain21-sudo/nfcore-longread-varcall'
    author          = 'Abyan Hussain'
    homePage        = 'https://github.com/abyanhussain21-sudo/nfcore-longread-varcall'
    description     = 'Haplotype-aware variant calling from PacBio HiFi long reads on non-model mammalian genomes. Modeled on nf-core conventions.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.1.0'
    doi             = ''
}

// ---------------------------------------------------------------------------
//  Reporting — Nextflow's built-in execution reports. Always on; cheap.
// ---------------------------------------------------------------------------
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
timeline { enabled = true; file = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html" }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt" }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.html" }

// ---------------------------------------------------------------------------
//  check_max — clamp per-process requests against the global ceilings.
//  Identical to the helper used in every nf-core pipeline. Documented here
//  rather than hidden away because a reviewer should not have to trace
//  imports to understand resource handling.
// ---------------------------------------------------------------------------
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "  ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "  ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj as int, params.max_cpus as int)
        } catch (all) {
            println "  ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
