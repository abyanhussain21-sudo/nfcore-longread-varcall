{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/abyanhussain21-sudo/nfcore-longread-varcall/master/assets/samplesheet_schema.json",
    "title": "nfcore-longread-varcall samplesheet schema",
    "description": "Schema for the input samplesheet required by the pipeline.",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._-]+$",
                "errorMessage": "sample_id must contain only [A-Za-z0-9._-]",
                "meta": ["id"]
            },
            "fastq": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(fastq|fq)(\\.gz)?$",
                "errorMessage": "fastq must be a path to a FASTQ file (.fastq, .fq, or gzipped)."
            },
            "reference": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(fa|fasta)(\\.gz)?$",
                "errorMessage": "reference must be a path to a FASTA file."
            }
        },
        "required": ["sample_id", "fastq", "reference"]
    }
}
